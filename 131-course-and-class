public void createCourseAndClass(String name, String description) {
    apxio__Course__c course = new apxio__Course__c(Name = name,apxio__Course_Details__c = description);
    insert course;
    String trimmedDescription = description.left(255);
    apxio__Class__c class = new apxio__Class__c(Name = name,apxio__Description__c = trimmedDescription,apxio__Course__c = course.Id);
    return class;
}