public class Stack {
    
    private List<Object> stackList = new List<Object>();
    public void push(Object obj) {
        //implement push
        stackList.add(obj);
    }
    
    public Object pop() {
        Integer size = stackList.size();
        if(size != 0)
        {
           return stackList.remove(size-1);
        }
        else{
            return new Object;
        }
    }
    
    public Integer size() {
        return stackList.size();
    }
    
    public Object peek(){
        return stackList.get(stackList.size()-1);
    }
    
    public Boolean isEmpty() {
        return stackList.size() == 0;
    }
}