public Map<String, List<Case>> casesByType(List<Case> cases) {
    Map<String, List<Case>> TypeCasesMap = new Map<String, List<Case>>();
    if(cases == null)
    {
        return TypeCasesMap;
    }
    for(Case c : cases)
    {
        if(c.Type != null)
        {
            if(! TypeCaseMap.containsKey(c.Type)){
                TypeCaseMap.put(c.Type,new List<Case>());
            }
            TypeCaseMap.get(c.Type).add(c));
        }
    }
    return TypeCasesMap;
}