public List<Integer> positiveIntegers(List<Integer> numbers) {
    
    if(numbers == null || numbers.size() == 0)
    {
        return numbers;
    }
    else 
    {
        List<Integer> cloneNum = numbers.clone();
        for(Integer i = numbers.size() - 1; i >= 0; i--)
        {
            if(numbers[i] <= 0)
            {
                cloneNum.remove(i);
            }
        }
        return cloneNum;
    }
}