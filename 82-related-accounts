public Set<Id> accountIds(List<Opportunity> opps) {
    Set<Id> accIdSet = new Set<Id>();
    if(opps == null)
    {
        return accIdSet;
    }
    for(Opportunity opp : opps){
        if(opp?.AccountId != null)
        {
            accIdSet.add(opp.AccountId);
        }
    }
    return accIdSet;
}