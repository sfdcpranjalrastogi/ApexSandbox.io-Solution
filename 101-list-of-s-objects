public List<sObject> getListOfsObject(List<Account> accounts, List<Contact> contacts)
{
    List<sObject> sObjList = new List<sObject>();
    if(accounts == null){
        for(Account acc : accounts){
        sObjList.add(acc);
        }
    }
    if(contacts == null){
        for(Contact con : contacts){
            sObjList.add(con);
        }
    }
    return sObjList;
}